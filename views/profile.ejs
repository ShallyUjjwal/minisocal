<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Profile</title>

    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>

<div class="p-10 w-full min-h-screen bg-zinc-900 text-white">

    <!-- LOGOUT -->
    <div class="w-full flex justify-end">
        <a 
            class="bg-red-500 hover:bg-red-700 text-white font-bold py-2 px-4 rounded" 
            href="/logout">
            Logout
        </a>
    </div>

    <hr class="my-5 border-zinc-600">

    <!-- PROFILE -->
    <h1 class="text-3xl font-bold">Profile</h1>

    <hr class="my-5 border-zinc-600">

    <div class="space-y-3 text-xl">

       
        <div class="flex items-start gap-3">
              <div class="w-10 h-10 overflow-hidden  ">
                <img class="w-full h-full object-cover  rounded-full" src="/images/uploads/<%= user.profilepic %>" alt="Profile Picture">
            </div>


        <h3> HELLO <%= user.name %></h3>
        </div>

        <h5 class="mb-5">You can create new post</h5>

        <!-- CREATE POST FORM -->
        <form action="/post" method="post">

            <textarea 
                name="content"
                rows="3"
                placeholder="What's on your mind?"
                class="block w-1/3 resize-none bg-transparent border border-zinc-600 focus:outline-none focus:ring-2 focus:ring-blue-500 p-2 rounded"></textarea>

            <button 
                type="submit"
                class="mt-3 bg-blue-500 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded">

                Create New Post

            </button>

        </form>

        <!-- POSTS -->
        <div class="posts mt-10">

            <h3 class="text-2xl font-bold mb-5">Your Posts</h3>

            <% user.posts.reverse().forEach(function(post) { %>

                <div class="postcontainer mb-5 bg-zinc-700 p-4 rounded">

                    <div class="post border-2 border-zinc-800 p-4 rounded">

                        <h4 class="text-blue-400 mb-2">
                            @<%= user.username %>
                        </h4>
<p class="text-sm tracking-tight">
    <%= post.content %>
</p>

<% if(post.likes.length > 0){ %>

    <p class="text-sm text-zinc-400 mt-3">
        <%= post.likes.length %> likes
    </p>

<% } %>

<div class="btns flex gap-5 mt-5">

    <% if(post.likes.includes(user._id)){ %>

        <a 
           class="text-red-400 hover:underline" 
           href="/like/<%= post._id %>">

           Unlike

        </a>

    <% } else { %>

        <a 
           class="text-blue-400 hover:underline" 
           href="/like/<%= post._id %>">

           Like

        </a>

    <% } %>

    <a class="text-green-500 hover:underline" href="/edit/<%= post._id %>">
        Edit
    </a>

</div>
                        
                    </div>

                </div>

            <% }) %>

        </div>

    </div>

</div>

</body>
</html>