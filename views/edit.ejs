<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Profile</title>

    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>

<div class="p-10 w-full min-h-screen bg-zinc-900 text-white">

    <!-- LOGOUT -->
    <div class="w-full flex justify-end">
        <a 
            class="bg-red-500 hover:bg-red-700 text-white font-bold py-2 px-4 rounded" 
            href="/logout">
            Logout
        </a>
    </div>

 <h5 class="mb-5">Edit your posts</h5>
        <!-- CREATE POST FORM -->
        <form action="/update/<%= post._id %>" method="post">

            <textarea 
                name="content"
                rows="3"
                placeholder="What's on your mind?"
                class="block w-1/3 resize-none bg-transparent border border-zinc-600 focus:outline-none focus:ring-2 focus:ring-blue-500 p-2 rounded">
            <%= post.content %>
            </textarea>

            <button 
                type="submit"
                class="mt-3  text-black bg-yellow-500 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded">

               Update Post

            </button>

        </form>

        <!-- POSTS -->



</div>

</body>
</html>
