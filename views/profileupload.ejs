<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>

    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>

</head>
<body>
    <div class="  p-10 w-full min-h-screen bg-zinc-900 text-white p-10">
        <h3 class="text-3x ">Upload profile picture </h3> 
        <hr class="my-2 border-zinc-600">
    

        <form  action="/upload"  method="post" enctype="multipart/form-data"  >
           <input 
        type="file" name="image" >
            <input type="submit" value="Upload" class="px-3 py-2 bg-blue-600 text-white hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500 ">

            </form>
    </div>
</body>
</html>